      "regex": "^/preview/dyreklinikken\\-son(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/preview/dyreklinikken\\-son(?:/)?$"
    },
    {
      "page": "/priser",
      "regex": "^/priser(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/priser(?:/)?$"
